{
  "name": "mta-api",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "openapi:dump": "DB_PATH=:memory: bun run scripts/openapi.ts",
    "seed": "bun run scripts/seed.ts",
    "lint": "oxlint src/ scripts/",
    "lint:fix": "oxlint --fix src/ scripts/",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:hurl": "sh scripts/hurl.sh test/e2e/contract.hurl test/e2e/stops.hurl",
    "test:hurl:all": "sh scripts/hurl.sh test/e2e/contract.hurl test/e2e/stops.hurl test/e2e/realtime.hurl"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "fflate": "^0.8.3",
    "hono": "^4.12.25",
    "papaparse": "^5.5.3",
    "protobufjs": "^8.6.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/papaparse": "^5.5.2",
    "@types/swagger-ui-dist": "^3.30.6",
    "oxlint": "^1.69.0",
    "swagger-ui-dist": "^5.32.6",
    "typescript": "5.9.3"
  }
}