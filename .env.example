# Server
PORT=3000
HOST=0.0.0.0

# Static feed refresh intervals (milliseconds)
SUBWAY_SYNC_INTERVAL_MS=3600000    # 1 hour
RAIL_SYNC_INTERVAL_MS=86400000     # 24 hours

# RT cache TTL
RT_CACHE_TTL_MS=20000              # 20 seconds

# Upstream fetch timeouts (milliseconds)
RT_FETCH_TIMEOUT_MS=10000          # 10 seconds (small RT protobuf feeds)
STATIC_FETCH_TIMEOUT_MS=60000      # 60 seconds (large static GTFS zips)

# SQLite file path (':memory:' for ephemeral dev, file path for prod)
DB_PATH=./data/mta.db

# Prebuilt-DB download (production topology). When DB_URL is set, start.sh fetches
# a prebuilt mta.db from this bucket base URL on boot (see scripts/fetch-db.ts)
# instead of syncing the feeds in-process. Leave unset for local dev, where you
# seed the DB yourself (`bun run seed`) or let it auto-seed with SYNC_ENABLED=true.
# DB_URL=https://mta-api-db.fly.storage.tigris.dev
# DB_FETCH_TIMEOUT_MS=120000

# In-instance static sync. 'true' (default) downloads/writes the feeds itself
# (local dev, first-boot auto-seed). Set 'false' in production, where a scheduled
# CI job builds the DB and instances only download it (see DB_URL above).
SYNC_ENABLED=true

# Log level
LOG_LEVEL=info                     # debug | info | warn | error
