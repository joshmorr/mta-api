# Server
PORT=3000
HOST=0.0.0.0

# RT cache TTL
RT_CACHE_TTL_MS=20000              # 20 seconds

# Upstream fetch timeouts (milliseconds)
RT_FETCH_TIMEOUT_MS=10000          # 10 seconds (small RT protobuf feeds)
STATIC_FETCH_TIMEOUT_MS=60000      # 60 seconds (large static GTFS zips)

# Rate limiting (per-instance fixed window; see src/middleware/rateLimit.ts)
RATE_LIMIT_MAX=100                 # requests per window per client IP
RATE_LIMIT_WINDOW_MS=60000         # 60 seconds

# SQLite file path (':memory:' for ephemeral dev, file path for prod)
DB_PATH=./data/mta.db

# Prebuilt-DB download (production topology). When DB_URL is set, start.sh fetches
# a prebuilt mta.db from this bucket base URL on boot (see scripts/fetch-db.ts).
# Leave unset for local dev, where you seed the DB yourself: `bun run seed`.
# DB_URL=https://lingering-frost-3143.fly.storage.tigris.dev
# DB_FETCH_TIMEOUT_MS=120000

# Log level
LOG_LEVEL=info                     # debug | info | warn | error
